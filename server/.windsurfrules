## Transformers (couche de sérialisation)

**Toujours utiliser les transformers pour les réponses API. Ne jamais sérialiser les modèles directement.**

```typescript
// app/transformers/post_transformer.ts
import { BaseTransformer } from '@adonisjs/core/transformers'
import type Post from '#models/post'

export default class PostTransformer extends BaseTransformer<Post> {
  toObject() {
    return {
      ...this.pick(this.resource, ['id', 'title', 'createdAt', 'updatedAt']),
      excerpt: this.resource.body.substring(0, 200),
    }
  }
}
```

### Dans les controllers
```typescript
import PostTransformer from '#transformers/post_transformer'

export default class PostsController {
  async show({ params, serialize }: HttpContext) {
    const post = await Post.findOrFail(params.id)
    return serialize({ post: PostTransformer.transform(post) })
  }
  async index({ serialize }: HttpContext) {
    const posts = await Post.all()
    return serialize({ posts: PostTransformer.transform(posts) })
  }
}
```

### Relations dans les transformers
```typescript
export default class PostTransformer extends BaseTransformer<Post> {
  toObject() {
    return {
      ...this.pick(this.resource, ['id', 'title']),
      author: UserTransformer.transform(this.resource.author),
      comments: CommentTransformer.transform(this.resource.comments).depth(2),
    }
  }
}
```

### Transformer avec DI (inject)
```typescript
import { inject } from '@adonisjs/core'
import { HttpContext } from '@adonisjs/core/http'

export default class PostTransformer extends BaseTransformer<Post> {
  toObject() {
    return this.pick(this.resource, ['id', 'title', 'createdAt'])
  }

  @inject()
  async forDetailedView({ auth }: HttpContext) {
    return {
      ...this.toObject(),
      can: {
        edit: auth.user?.id === this.resource.userId,
        delete: auth.user?.id === this.resource.userId,
      },
    }
  }
}
```

