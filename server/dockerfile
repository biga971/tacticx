FROM node:lts-bookworm-slim AS base

# ----------------------------
# Stage 1: pnpm via corepack
# Pin to the version verified locally (10.2.0). `pnpm@latest` drifts and
# changed the build-script gating behavior, breaking CI installs.
# ----------------------------
RUN corepack enable && corepack prepare pnpm@10.2.0 --activate

# ----------------------------
# Stage 2: Install all dependencies (reproducible via lockfile)
# Native build scripts (better-sqlite3, esbuild, @swc/core) are whitelisted
# via pnpm.onlyBuiltDependencies in package.json.
# ----------------------------
FROM base AS deps
WORKDIR /app
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# ----------------------------
# Stage 3: Build the application
# ----------------------------
FROM deps AS build
WORKDIR /app
COPY . .
RUN node ace build

# ----------------------------
# Stage 4: Production runtime
# ----------------------------
FROM base AS production
WORKDIR /app
ENV NODE_ENV=production

# `node ace build` copies package.json + pnpm-lock.yaml into build/.
COPY --from=build /app/build ./
RUN pnpm install --prod --frozen-lockfile

EXPOSE 3333
CMD ["node", "bin/server.js"]
