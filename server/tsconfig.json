{
  "extends": "@adonisjs/tsconfig/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": "./",
    "jsx": "react",
    "outDir": "./build",
    "paths": {
      "#app": ["./app"],
      "#app/*": ["./app/*"],
      "#config": ["./config"],
      "#config/*": ["./config/*"],
      "#controllers": ["./app/controllers"],
      "#controllers/*": ["./app/controllers/*"],
      "#database": ["./database"],
      "#database/*": ["./database/*"],
      "#database/schema": ["./database/schema.ts"],
      "#enums": ["./app/enums"],
      "#enums/*": ["./app/enums/*"],
      "#events": ["./app/events"],
      "#events/*": ["./app/events/*"],
      "#exceptions": ["./app/exceptions"],
      "#exceptions/*": ["./app/exceptions/*"],
      "#guards": ["./app/guards"],
      "#guards/*": ["./app/guards/*"],
      "#generated": ["./.adonisjs/server"],
      "#generated/*": ["./.adonisjs/server/*"],
      "#listeners": ["./app/listeners"],
      "#listeners/*": ["./app/listeners/*"],
      "#mails": ["./app/mails"],
      "#mails/*": ["./app/mails/*"],
      "#middleware": ["./app/middleware"],
      "#middleware/*": ["./app/middleware/*"],
      "#models": ["./app/models"],
      "#models/*": ["./app/models/*"],
      "#policies": ["./app/policies"],
      "#policies/*": ["./app/policies/*"],
      "#abilities": ["./app/abilities"],
      "#abilities/*": ["./app/abilities/*"],
      "#providers": ["./providers"],
      "#providers/*": ["./providers/*"],
      "#services": ["./app/services"],
      "#services/*": ["./app/services/*"],
      "#start": ["./start"],
      "#start/*": ["./start/*"],
      "#tests": ["./tests"],
      "#tests/*": ["./tests/*"],
      "#transformers": ["./app/transformers"],
      "#transformers/*": ["./app/transformers/*"],
      "#utils": ["./app/utils"],
      "#utils/*": ["./app/utils/*"],
      "#validators": ["./app/validators"],
      "#validators/*": ["./app/validators/*"]
    }
  },
  "references": [{ "path": "./tsconfig.inertia.json" }]
}
